# Copy this to .env.local and fill in real values. .env.local is gitignored.

# === Database ===
# MongoDB Atlas connection string. Free tier is fine.
# Format: mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/pofolio?retryWrites=true&w=majority
MONGODB_URI=

# === App ===
# Used to construct absolute URLs (OG images, password reset emails, the QR target).
# In dev: http://localhost:3000
# In prod: https://pofoliox.vercel.app  (or your custom domain)
NEXT_PUBLIC_APP_URL=https://pofoliox.vercel.app

# === NextAuth ===
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Optional OAuth providers — leave blank to disable. Get these from each
# provider's developer console.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# === Integrations ===
# GitHub personal access token (no scopes needed for public read).
# Without this you get 60 req/hour shared across all your users.
# With it: 5000 req/hour. Create at https://github.com/settings/tokens
GITHUB_TOKEN=

# === Cloudinary (file uploads) ===
# Sign up free at https://cloudinary.com — dashboard shows these values.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Public mirror of CLOUDINARY_CLOUD_NAME — same value, exposed to the browser
# so it can build delivery URLs for avatars and project images. Safe to expose
# (cloud names are public anyway; only API_SECRET must stay server-side).
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# === Email (for password reset) — pick one ===
# Resend is the easiest. Free tier: 3000 emails/month.
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com
